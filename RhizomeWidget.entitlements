<plist version="1.0">
<dict>
    <!-- The widget only deep-links into the app (rhizome://capture); it reads no shared data,
         so it needs no App Group / Keychain entitlements. Keeping this empty lets cloud signing
         issue a matching provisioning profile for org.syslinx.rhizome.Widget. -->
</dict>
</plist>
