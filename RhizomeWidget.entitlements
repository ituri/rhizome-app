<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- Same App Group as the app + Share Extension, so the medium widget can read the
         snapshot of today's capture-bullet items the app publishes. Requires the App Groups
         capability to be enabled for org.syslinx.rhizome.Widget in the Apple Developer portal. -->
    <key>com.apple.security.application-groups</key>
    <array>
        <string>group.org.syslinx.rhizome</string>
    </array>
</dict>
</plist>
